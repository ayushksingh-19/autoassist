{
  "name": "autoassist",
  "version": "1.0.0",
  "description": "Full-stack roadside assistance platform for booking vehicle help, tracking requests, and managing users.",
  "homepage": "https://autoassist-frontend.onrender.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayushksingh-19/autoassist.git"
  },
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "check": "npm run check --prefix backend",
    "build": "npm run build --prefix frontend",
    "audit:backend": "npm audit --omit=dev --prefix backend",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "npm start --prefix frontend"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "joi": "^18.1.1"
  }
}
